<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mahfooj Alam — Software Developer</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap"
    rel="stylesheet" />
  <style>
    /* ══════════════ TOKENS ══════════════ */
    :root {
      --void: #080a06;
      --deep: #0c0e0a;
      --surface: #111410;
      --panel: #151812;
      --border: rgba(184, 150, 12, 0.1);
      --border2: rgba(184, 150, 12, 0.22);
      --cyan: #b8960c;
      --cyan2: #d4a017;
      --amber: #ff6b35;
      --rose: #cc2200;
      --text: #e8f4f8;
      --muted: rgba(232, 244, 248, 0.45);
      --dim: rgba(232, 244, 248, 0.2);
      --font-display: 'Bebas Neue', sans-serif;
      --font-body: 'Cormorant Garamond', Georgia, serif;
      --font-code: 'JetBrains Mono', monospace;
    }

    /* ══════════════ RESET ══════════════ */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      background: var(--void);
      color: var(--text);
      font-family: var(--font-body);
      overflow-x: hidden;
      cursor: none;
    }

    ::-webkit-scrollbar {
      width: 2px;
    }

    ::-webkit-scrollbar-thumb {
      background: var(--cyan);
      opacity: .6;
    }

    /* ══════════════ CURSOR ══════════════ */
    .cursor {
      position: fixed;
      z-index: 9999;
      pointer-events: none;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--cyan);
      transform: translate(-50%, -50%);
      transition: width .2s, height .2s, opacity .2s;
      mix-blend-mode: difference;
    }

    .cursor-ring {
      position: fixed;
      z-index: 9998;
      pointer-events: none;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(0, 212, 255, 0.5);
      transform: translate(-50%, -50%);
      transition: all .12s ease-out;
    }

    body:hover .cursor {
      opacity: 1;
    }

    /* ══════════════ NAV ══════════════ */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 20px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(2, 2, 10, 0);
      backdrop-filter: blur(0px);
      border-bottom: 1px solid transparent;
      transition: all .4s ease;
    }

    nav.scrolled {
      background: rgba(2, 2, 10, 0.92);
      backdrop-filter: blur(20px);
      border-bottom-color: var(--border);
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 22px;
      letter-spacing: .08em;
      color: var(--cyan);
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-code);
      font-size: 12px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: .06em;
      text-transform: uppercase;
      transition: color .2s;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      right: 0;
      height: 1px;
      background: var(--cyan);
      transform: scaleX(0);
      transition: transform .25s;
    }

    .nav-links a:hover {
      color: var(--cyan);
    }

    .nav-links a:hover::after {
      transform: scaleX(1);
    }

    .nav-cta {
      display: none;
    }

    /* ══════════════ HERO ══════════════ */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding: 120px 48px 80px;
    }

    .hero-canvas {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(184, 150, 12, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(184, 150, 12, 0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: gridPan 20s linear infinite;
    }

    @keyframes gridPan {
      from {
        transform: translateY(0);
      }

      to {
        transform: translateY(60px);
      }
    }

    .hero-glow1 {
      position: absolute;
      top: -20%;
      left: -10%;
      width: 700px;
      height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(180, 60, 10, 0.22) 0%, transparent 70%);
      animation: breathe 6s ease-in-out infinite;
    }

    .hero-glow2 {
      position: absolute;
      bottom: -30%;
      right: -5%;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(100, 80, 0, 0.18) 0%, transparent 70%);
      animation: breathe 8s ease-in-out infinite reverse;
    }

    @keyframes breathe {

      0%,
      100% {
        transform: scale(1);
      }

      50% {
        transform: scale(1.12);
      }
    }

    .hero-noise {
      position: absolute;
      inset: 0;
      opacity: .025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 780px;
    }

    .hero-label {
      font-family: var(--font-code);
      font-size: 12px;
      color: var(--cyan);
      letter-spacing: .2em;
      text-transform: uppercase;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .hero-label::before {
      content: '';
      width: 40px;
      height: 1px;
      background: var(--cyan);
    }

    .hero-name {
      font-family: var(--font-display);
      font-size: clamp(72px, 10vw, 140px);
      line-height: .9;
      letter-spacing: .02em;
      color: var(--text);
      margin-bottom: 8px;
      position: relative;
    }

    .hero-name span {
      -webkit-text-stroke: 1px var(--cyan);
      color: transparent;
    }

    .hero-role {
      font-family: var(--font-display);
      font-size: clamp(24px, 4vw, 52px);
      color: var(--cyan);
      letter-spacing: .08em;
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .hero-role::after {
      content: '';
      flex: 1;
      max-width: 200px;
      height: 1px;
      background: linear-gradient(90deg, var(--cyan), transparent);
    }

    .hero-bio {
      font-size: 18px;
      line-height: 1.8;
      color: var(--muted);
      max-width: 560px;
      margin-bottom: 48px;
      font-weight: 300;
      font-style: italic;
      border-left: 2px solid var(--cyan);
      padding-left: 20px;
    }

    .hero-actions {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 64px;
    }

    .btn-primary {
      padding: 16px 40px;
      font-family: var(--font-code);
      font-size: 12px;
      letter-spacing: .1em;
      text-transform: uppercase;
      text-decoration: none;
      background: linear-gradient(135deg, var(--cyan), var(--cyan2));
      color: var(--void);
      border: none;
      cursor: none;
      transition: transform .15s, box-shadow .2s;
      box-shadow: 0 0 40px rgba(0, 212, 255, 0.25);
      clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 60px rgba(0, 212, 255, 0.45);
    }

    .btn-secondary {
      padding: 15px 36px;
      font-family: var(--font-code);
      font-size: 12px;
      letter-spacing: .1em;
      text-transform: uppercase;
      text-decoration: none;
      background: transparent;
      color: var(--text);
      border: 1px solid rgba(255, 255, 255, 0.2);
      cursor: none;
      transition: all .2s;
      clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    }

    .btn-secondary:hover {
      border-color: var(--cyan);
      color: var(--cyan);
    }

    .hero-stats {
      display: flex;
      gap: 48px;
      border-top: 1px solid var(--border);
      padding-top: 32px;
    }

    .stat-item {
      text-align: left;
    }

    .stat-val {
      font-family: var(--font-display);
      font-size: 42px;
      color: var(--cyan);
      line-height: 1;
    }

    .stat-lbl {
      font-family: var(--font-code);
      font-size: 11px;
      color: var(--dim);
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* FLOATING CODE BLOCK */
    .hero-code {
      position: absolute;
      right: 48px;
      top: 50%;
      transform: translateY(-50%);
      background: var(--panel);
      border: 1px solid var(--border2);
      padding: 28px 32px;
      font-family: var(--font-code);
      font-size: 13px;
      line-height: 1.9;
      max-width: 380px;
      z-index: 2;
      animation: floatCode 6s ease-in-out infinite;
      box-shadow: 0 0 80px rgba(0, 212, 255, 0.08), inset 0 0 40px rgba(0, 212, 255, 0.02);
    }

    @keyframes floatCode {

      0%,
      100% {
        transform: translateY(-50%);
      }

      50% {
        transform: translateY(calc(-50% - 12px));
      }
    }

    .hero-code::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    }

    .code-line {
      color: var(--dim);
    }

    .code-key {
      color: #79d9ff;
    }

    .code-str {
      color: var(--cyan2);
    }

    .code-num {
      color: var(--amber);
    }

    .code-comment {
      color: rgba(232, 244, 248, 0.25);
      font-style: italic;
    }

    .code-cursor {
      display: inline-block;
      width: 2px;
      height: 14px;
      background: var(--cyan);
      vertical-align: middle;
      animation: blink 1s step-end infinite;
    }

    @keyframes blink {

      0%,
      100% {
        opacity: 1;
      }

      50% {
        opacity: 0;
      }
    }

    /* ══════════════ SECTION BASE ══════════════ */
    section {
      padding: 100px 48px;
      position: relative;
    }

    .section-tag {
      font-family: var(--font-code);
      font-size: 11px;
      color: var(--cyan);
      letter-spacing: .2em;
      text-transform: uppercase;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-tag::before {
      content: '//';
      color: var(--dim);
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(48px, 6vw, 90px);
      line-height: .95;
      letter-spacing: .03em;
      margin-bottom: 60px;
    }

    .section-title em {
      font-style: normal;
      -webkit-text-stroke: 1px var(--muted);
      color: transparent;
    }

    /* ══════════════ SKILLS ══════════════ */
    #skills {
      background: var(--deep);
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 2px;
      margin-top: 0;
    }

    .skill-cell {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 32px;
      position: relative;
      overflow: hidden;
      transition: all .3s;
      cursor: none;
    }

    .skill-cell::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(0, 212, 255, 0.06), transparent);
      opacity: 0;
      transition: opacity .3s;
    }

    .skill-cell:hover {
      border-color: var(--border2);
    }

    .skill-cell:hover::before {
      opacity: 1;
    }

    .skill-cell:hover .skill-bar-fill {
      box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
    }

    .skill-icon {
      font-size: 28px;
      margin-bottom: 16px;
    }

    .skill-name {
      font-family: var(--font-code);
      font-size: 13px;
      color: var(--text);
      letter-spacing: .04em;
      margin-bottom: 8px;
      text-transform: uppercase;
    }

    .skill-tag {
      display: inline-flex;
      font-family: var(--font-code);
      font-size: 10px;
      color: var(--cyan);
      background: rgba(0, 212, 255, 0.08);
      padding: 3px 10px;
      border-radius: 2px;
      letter-spacing: .06em;
      margin-bottom: 16px;
    }

    .skill-bar {
      height: 2px;
      background: rgba(255, 255, 255, 0.06);
      margin-top: 12px;
    }

    .skill-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--cyan), var(--cyan2));
      transition: width 1.5s cubic-bezier(.22, 1, .36, 1);
    }

    /* ══════════════ PROJECTS ══════════════ */
    #projects {
      overflow: hidden;
    }

    .projects-layout {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .project-card {
      background: var(--panel);
      border: 1px solid var(--border);
      display: grid;
      grid-template-columns: 80px 1fr auto;
      align-items: center;
      gap: 40px;
      padding: 36px 48px;
      position: relative;
      overflow: hidden;
      transition: all .3s var(--ease, cubic-bezier(.22, 1, .36, 1));
      cursor: none;
    }

    .project-card::after {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--cyan), var(--cyan2));
      transform: scaleY(0);
      transition: transform .35s;
      transform-origin: top;
    }

    .project-card:hover {
      background: var(--surface);
      border-color: var(--border2);
    }

    .project-card:hover::after {
      transform: scaleY(1);
    }

    .project-num {
      font-family: var(--font-display);
      font-size: 48px;
      color: rgba(0, 212, 255, 0.15);
      line-height: 1;
    }

    .project-body {
      min-width: 0;
    }

    .project-name {
      font-family: var(--font-display);
      font-size: 32px;
      letter-spacing: .04em;
      margin-bottom: 8px;
      line-height: 1;
    }

    .project-desc {
      font-size: 16px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 16px;
      font-weight: 300;
    }

    .project-tech {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .tech-tag {
      font-family: var(--font-code);
      font-size: 10px;
      color: var(--cyan2);
      background: rgba(0, 255, 204, 0.06);
      border: 1px solid rgba(0, 255, 204, 0.15);
      padding: 4px 12px;
      letter-spacing: .06em;
    }

    .project-arrow {
      font-size: 24px;
      color: var(--dim);
      transition: all .25s;
      flex-shrink: 0;
    }

    .project-card:hover .project-arrow {
      color: var(--cyan);
      transform: translate(4px, -4px);
    }

    /* ══════════════ EXPERIENCE ══════════════ */
    #experience {
      background: var(--deep);
    }

    .timeline {
      position: relative;
      padding-left: 32px;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, var(--cyan), transparent);
    }

    .timeline-item {
      position: relative;
      margin-bottom: 60px;
      animation: slideIn .6s ease forwards;
      opacity: 0;
    }

    .timeline-item:nth-child(1) {
      animation-delay: .1s;
    }

    .timeline-item:nth-child(2) {
      animation-delay: .25s;
    }

    .timeline-item:nth-child(3) {
      animation-delay: .4s;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }

    .timeline-dot {
      position: absolute;
      left: -39px;
      top: 4px;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--void);
      border: 2px solid var(--cyan);
      box-shadow: 0 0 12px rgba(0, 212, 255, 0.5);
    }

    .timeline-period {
      font-family: var(--font-code);
      font-size: 11px;
      color: var(--cyan);
      letter-spacing: .1em;
      margin-bottom: 8px;
    }

    .timeline-title {
      font-family: var(--font-display);
      font-size: 28px;
      letter-spacing: .04em;
      margin-bottom: 4px;
      line-height: 1;
    }

    .timeline-sub {
      font-family: var(--font-code);
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 12px;
      letter-spacing: .04em;
    }

    .timeline-desc {
      font-size: 16px;
      color: var(--muted);
      line-height: 1.7;
      font-weight: 300;
    }

    /* ══════════════ ABOUT / EXTRAS ══════════════ */
    #about {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }

    .about-visual {
      position: relative;
      height: 480px;
    }

    .about-frame {
      position: absolute;
      inset: 0;
      border: 1px solid var(--border2);
      background: var(--panel);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .about-frame::before {
      content: 'MA';
      font-family: var(--font-display);
      font-size: 220px;
      color: rgba(0, 212, 255, 0.04);
      letter-spacing: -.02em;
      position: absolute;
    }

    .about-frame-inner {
      position: relative;
      z-index: 1;
      text-align: center;
    }

    .about-avatar {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      margin: 0 auto 20px;
      background: linear-gradient(135deg, rgba(0, 212, 255, 0.2), rgba(0, 255, 204, 0.1));
      border: 1px solid var(--border2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 60px;
      color: var(--cyan);
      box-shadow: 0 0 60px rgba(0, 212, 255, 0.2);
    }

    .about-name-lg {
      font-family: var(--font-display);
      font-size: 24px;
      letter-spacing: .06em;
      margin-bottom: 4px;
    }

    .about-tag {
      font-family: var(--font-code);
      font-size: 11px;
      color: var(--cyan);
      letter-spacing: .1em;
    }

    .about-corner {
      position: absolute;
      width: 30px;
      height: 30px;
      border-color: var(--cyan);
      border-style: solid;
    }

    .about-corner.tl {
      top: -1px;
      left: -1px;
      border-width: 2px 0 0 2px;
    }

    .about-corner.tr {
      top: -1px;
      right: -1px;
      border-width: 2px 2px 0 0;
    }

    .about-corner.bl {
      bottom: -1px;
      left: -1px;
      border-width: 0 0 2px 2px;
    }

    .about-corner.br {
      bottom: -1px;
      right: -1px;
      border-width: 0 2px 2px 0;
    }

    .about-text .section-title {
      font-size: clamp(36px, 4vw, 64px);
      margin-bottom: 24px;
    }

    .about-info {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 32px 0;
    }

    .info-item {
      background: var(--panel);
      border: 1px solid var(--border);
      padding: 16px 20px;
    }

    .info-label {
      font-family: var(--font-code);
      font-size: 10px;
      color: var(--dim);
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: 6px;
    }

    .info-val {
      font-size: 16px;
      color: var(--text);
      font-weight: 300;
    }

    .lang-row {
      display: flex;
      justify-content: space-between;
      margin-top: 24px;
      gap: 16px;
    }

    .lang-item {
      flex: 1;
      background: var(--panel);
      border: 1px solid var(--border);
      padding: 20px;
      text-align: center;
    }

    .lang-name {
      font-family: var(--font-display);
      font-size: 22px;
      letter-spacing: .06em;
      margin-bottom: 4px;
    }

    .lang-lvl {
      font-family: var(--font-code);
      font-size: 10px;
      color: var(--cyan);
      letter-spacing: .08em;
    }

    /* ══════════════ CONTACT ══════════════ */
    #contact {
      text-align: center;
      background: var(--deep);
      position: relative;
      overflow: hidden;
    }

    .contact-glow {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 800px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(0, 212, 255, 0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .contact-big {
      font-family: var(--font-display);
