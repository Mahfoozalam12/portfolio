    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursor-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
    });
    function animRing() {
      rx += (mx - rx) * .12; ry += (my - ry) * .12;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(animRing);
    }
    animRing();
    document.querySelectorAll('a,button,.skill-cell,.project-card,.hobby-pill').forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursor.style.width = '20px'; cursor.style.height = '20px';
        ring.style.width = '60px'; ring.style.height = '60px';
        ring.style.borderColor = 'rgba(184,150,12,0.9)';
      });
      el.addEventListener('mouseleave', () => {
        cursor.style.width = '10px'; cursor.style.height = '10px';
        ring.style.width = '36px'; ring.style.height = '36px';
        ring.style.borderColor = 'rgba(184,150,12,0.5)';
      });
    });

    /* ── NAV SCROLL ── */
    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
    });

    /* ── WAR-TORN WORLD ENGINE ── */
    const canvas = document.getElementById('portfolio-canvas');
    const ctx = canvas.getContext('2d');
    let W, H;
    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);

    // ── STORM CLOUDS ──
    const clouds = [];
    for (let i = 0; i < 22; i++) {
      clouds.push({
        x: Math.random(), y: Math.random() * .45,
        w: Math.random() * .35 + .15, h: Math.random() * .12 + .06,
        speed: Math.random() * .0003 + .0001,
        alpha: Math.random() * .55 + .25,
        dark: Math.random() > .4
      });
    }

    // ── LIGHTNING ──
    const bolts = [];
    let boltTimer = 0;
    function spawnBolt() {
      const x = Math.random() * .8 + .1;
      const segs = []; let cx = x, cy = .05;
      while (cy < .75) { const a = (Math.random() - .5) * .4; cx += a * .04; cy += Math.random() * .06 + .04; segs.push({ x: cx, y: cy }); }
      bolts.push({ segs, alpha: 1, life: 0, maxLife: Math.random() * 8 + 4, x });
    }

    // ── EMBERS / ASH ──
    const embers = [];
    function makeEmber() {
      return {
        x: Math.random(), y: .5 + Math.random() * .5,
        vx: (Math.random() - .5) * .003, vy: -(Math.random() * .004 + .001),
        r: Math.random() * 2.5 + .5,
        alpha: Math.random() * .8 + .2,
        life: 0, maxLife: 120 + Math.random() * 180,
        hot: Math.random() > .6
      };
    }
    for (let i = 0; i < 200; i++) { const e = makeEmber(); e.life = Math.random() * e.maxLife; embers.push(e); }

    // ── RAVENS ──
    const ravens = [];
    for (let i = 0; i < 8; i++) {
      ravens.push({
        x: Math.random(), y: .12 + Math.random() * .25,
        vx: (Math.random() * .002 + .001) * (Math.random() > .5 ? 1 : -1),
        wingPhase: Math.random() * Math.PI * 2,
        wingSpeed: Math.random() * .08 + .05,
        size: Math.random() * 8 + 6,
        alpha: Math.random() * .7 + .3
      });
    }

    // ── CRACKED GROUND ──
    const cracks = [];
    function buildCrack(sx, sy) {
      const pts = [{ x: sx, y: sy }];
      let cx = sx, cy = sy;
      for (let i = 0; i < 12; i++) {
        cx += (Math.random() - .5) * .06; cy += Math.random() * .04 + .01;
        pts.push({ x: cx, y: cy });
      }
      return pts;
    }
    for (let i = 0; i < 18; i++) cracks.push(buildCrack(Math.random(), Math.random() * .25 + .72));

    // ── FIRE COLUMNS ──
    const fires = [];
    for (let i = 0; i < 5; i++) {
      fires.push({
        x: .05 + i * .22 + Math.random() * .08,
        y: .68 + Math.random() * .06,
        w: Math.random() * .04 + .02,
        h: Math.random() * .15 + .1,
        phase: Math.random() * Math.PI * 2,
        speed: Math.random() * .04 + .03
      });
    }

    // ── RUINS (broken pillars) ──
    const ruins = [
      { x: .08, y: .66, w: .025, h: .18, broken: .7 },
      { x: .18, y: .60, w: .022, h: .24, broken: .5 },
      { x: .82, y: .64, w: .025, h: .20, broken: .6 },
      { x: .91, y: .58, w: .022, h: .26, broken: .4 },
      { x: .55, y: .62, w: .028, h: .22, broken: .55 },
    ];

    // ── DUST STREAKS ──
    const dust = [];
    for (let i = 0; i < 40; i++) {
      dust.push({
        x: Math.random(), y: .5 + Math.random() * .4,
        len: Math.random() * .08 + .02,
        alpha: Math.random() * .15 + .04,
        vy: -(Math.random() * .002 + .0005)
      });
    }

    let T = 0;
    function drawWar() {
      ctx.clearRect(0, 0, W, H);
      T += 1;

      // ── SKY — dead charcoal ──
      const sky = ctx.createLinearGradient(0, 0, 0, H * .75);
      sky.addColorStop(0, '#050603');
      sky.addColorStop(.25, '#0e0f0a');
      sky.addColorStop(.55, '#1a1408');
      sky.addColorStop(1, '#2a1a06');
      ctx.fillStyle = sky;
      ctx.fillRect(0, 0, W, H);

      // ── HORIZON EMBER GLOW ──
      const hg = ctx.createLinearGradient(0, H * .55, 0, H * .78);
      hg.addColorStop(0, 'transparent');
      hg.addColorStop(.4, 'rgba(180,60,5,0.18)');
      hg.addColorStop(1, 'rgba(220,80,0,0.35)');
      ctx.fillStyle = hg;
      ctx.fillRect(0, H * .55, W, H * .25);

      // ── STORM CLOUDS ──
      clouds.forEach(c => {
        c.x += c.speed; if (c.x > 1.3) c.x = -c.w - .1;
        const cx = c.x * W, cy = c.y * H, cw = c.w * W, ch = c.h * H;
        const cg = ctx.createRadialGradient(cx + cw / 2, cy + ch / 2, ch * .1, cx + cw / 2, cy + ch / 2, cw * .6);
        const base = c.dark ? '15,14,10' : '25,22,14';
        cg.addColorStop(0, `rgba(${base},${c.alpha})`);
        cg.addColorStop(1, `rgba(${base},0)`);
        ctx.beginPath(); ctx.ellipse(cx + cw / 2, cy + ch / 2, cw / 2, ch / 2, 0, 0, Math.PI * 2);
        ctx.fillStyle = cg; ctx.fill();
        // cloud detail lumps
        for (let l = 0; l < 4; l++) {
          const lx = cx + cw * .15 * l + cw * .1, lr = ch * .4 + Math.random() * .1;
          ctx.beginPath(); ctx.arc(lx, cy + ch * .4, lr, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${base},${c.alpha * .6})`; ctx.fill();
        }
      });

      // ── DISTANT RUINED CITY SILHOUETTE ──
      ctx.fillStyle = 'rgba(8,9,6,0.95)';
      ctx.beginPath(); ctx.moveTo(0, H * .72);
      const bldgs = [
        [0, .72], [.04, .58], [.07, .72], [.09, .5], [.12, .72], [.16, .54], [.2, .72],
        [.23, .48], [.26, .72], [.3, .52], [.34, .66], [.38, .44], [.42, .72],
        [.46, .5], [.5, .64], [.54, .46], [.58, .72], [.62, .52], [.66, .6],
        [.7, .48], [.74, .72], [.78, .55], [.82, .72], [.86, .5], [.9, .72],
        [.93, .56], [.97, .72], [1, .72]
      ];
      bldgs.forEach(([bx, by]) => ctx.lineTo(bx * W, by * H));
      ctx.lineTo(W, H * .72); ctx.lineTo(0, H * .72); ctx.closePath(); ctx.fill();

      // ── RUINS (broken pillars) ──
      ruins.forEach(r => {
        const rx = r.x * W, ry = r.y * H, rw = r.w * W, rh = r.h * H;
        // base pillar
        const rg = ctx.createLinearGradient(rx, ry, rx + rw, ry);
        rg.addColorStop(0, '#1a1a14'); rg.addColorStop(.5, '#2a2a1e'); rg.addColorStop(1, '#111108');
        ctx.fillStyle = rg;
        ctx.fillRect(rx, ry, rw, rh);
        // break line
        const by = ry + rh * r.broken;
        ctx.beginPath(); ctx.moveTo(rx - rw * .3, by); ctx.lineTo(rx + rw * 1.3, by + rw * .5);
        ctx.strokeStyle = 'rgba(5,4,2,0.9)'; ctx.lineWidth = 3; ctx.stroke();
        // ember glow on rubble
        const eg = ctx.createRadialGradient(rx + rw / 2, by + 4, 0, rx + rw / 2, by + 4, rw * 2);
        eg.addColorStop(0, 'rgba(200,80,0,0.3)'); eg.addColorStop(1, 'transparent');
        ctx.fillStyle = eg; ctx.fillRect(rx - rw, by, rw * 3, rw * 3);
      });

      // ── FIRE COLUMNS ──
      fires.forEach(f => {
        f.phase += f.speed;
        const fx = f.x * W, fy = f.y * H, fw = f.w * W, fh = f.h * H;
        const flicker = 1 + Math.sin(f.phase) * .15;
        for (let layer = 3; layer >= 0; layer--) {
          const lh = fh * flicker * (1 - layer * .15);
          const lg = ctx.createLinearGradient(fx, fy, fx, fy - lh);
          if (layer === 0) {
            lg.addColorStop(0, 'rgba(255,220,50,0.9)');
            lg.addColorStop(.3, 'rgba(255,100,0,0.8)');
            lg.addColorStop(.7, 'rgba(200,40,0,0.4)');
            lg.addColorStop(1, 'rgba(100,20,0,0)');
          } else {
            lg.addColorStop(0, `rgba(200,${80 - layer * 15},0,${0.3 - layer * .05})`);
            lg.addColorStop(1, 'transparent');
          }
          ctx.beginPath();
          ctx.ellipse(fx + fw / 2, fy, fw / 2 * (1 + layer * .3), lh / 2, 0, 0, Math.PI * 2);
          ctx.fillStyle = lg; ctx.fill();
        }
      });

      // ── CRACKED GROUND ──
      ctx.save(); ctx.globalAlpha = 0.6;
      cracks.forEach(pts => {
        ctx.beginPath(); ctx.moveTo(pts[0].x * W, pts[0].y * H);
        for (let i = 1; i < pts.length; i++) ctx.lineTo(pts[i].x * W, pts[i].y * H);
        ctx.strokeStyle = 'rgba(180,80,0,0.35)'; ctx.lineWidth = 1; ctx.stroke();
        // glow inside crack
        ctx.strokeStyle = 'rgba(255,120,0,0.12)'; ctx.lineWidth = 3; ctx.stroke();
      });
      ctx.restore();

      // ── GROUND ──
      const gg = ctx.createLinearGradient(0, H * .72, 0, H);
      gg.addColorStop(0, '#1a1208'); gg.addColorStop(.4, '#0f0d06'); gg.addColorStop(1, '#050402');
      ctx.fillStyle = gg; ctx.fillRect(0, H * .72, W, H * .28);

      // ── GROUND DETAIL — scorched texture ──
      for (let i = 0; i < 6; i++) {
        const gx = (i * .18 + .04) * W, gy = H * .74;
        const sg = ctx.createRadialGradient(gx, gy, 0, gx, gy, W * .08);
        sg.addColorStop(0, 'rgba(0,0,0,0.7)'); sg.addColorStop(1, 'transparent');
        ctx.beginPath(); ctx.ellipse(gx, gy, W * .09, H * .03, 0, 0, Math.PI * 2);
        ctx.fillStyle = sg; ctx.fill();
      }

      // ── RAVENS ──
      ravens.forEach(r => {
        r.x += r.vx; r.wingPhase += r.wingSpeed;
        if (r.x > 1.1) r.x = -.05; if (r.x < -.1) r.x = 1.05;
        const rx = r.x * W, ry = r.y * H, rs = r.size;
        const wing = Math.sin(r.wingPhase) * rs * .8;
        ctx.save(); ctx.globalAlpha = r.alpha;
        ctx.fillStyle = '#0a0906';
        // body
        ctx.beginPath(); ctx.ellipse(rx, ry, rs * .7, rs * .3, 0, 0, Math.PI * 2); ctx.fill();
        // wings
        ctx.beginPath(); ctx.moveTo(rx, ry);
        ctx.quadraticCurveTo(rx - rs, ry - wing, rx - rs * 2, ry + rs * .2); ctx.fill();
        ctx.beginPath(); ctx.moveTo(rx, ry);
        ctx.quadraticCurveTo(rx + rs, ry - wing, rx + rs * 2, ry + rs * .2); ctx.fill();
        // head
        ctx.beginPath(); ctx.arc(rx + rs * .5, ry - rs * .2, rs * .25, 0, Math.PI * 2); ctx.fill();
        ctx.restore();
      });

      // ── LIGHTNING ──
      boltTimer++;
      if (boltTimer > 120 + Math.random() * 200) { boltTimer = 0; spawnBolt(); }
      for (let i = bolts.length - 1; i >= 0; i--) {
        const b = bolts[i]; b.life++;
        const a = b.alpha * (1 - b.life / b.maxLife);
        if (b.life > b.maxLife) { bolts.splice(i, 1); continue; }
        // sky flash
        if (b.life < 3) {
          ctx.fillStyle = `rgba(220,200,100,${.06 * (1 - b.life / 3)})`;
          ctx.fillRect(0, 0, W, H * .5);
        }
        ctx.beginPath(); ctx.moveTo(b.x * W, 0);
        b.segs.forEach(s => ctx.lineTo(s.x * W, s.y * H));
        ctx.strokeStyle = `rgba(255,240,180,${a})`; ctx.lineWidth = 1.5; ctx.stroke();
        ctx.strokeStyle = `rgba(255,255,255,${a * .5})`; ctx.lineWidth = .5; ctx.stroke();
      }

      // ── EMBERS ──
      embers.forEach(e => {
        e.life++; e.x += e.vx; e.y += e.vy;
        if (e.life > e.maxLife || e.y < .1) { Object.assign(e, makeEmber()); }
        const ea = e.alpha * (1 - e.life / e.maxLife);
        ctx.beginPath(); ctx.arc(e.x * W, e.y * H, e.r, 0, Math.PI * 2);
        ctx.fillStyle = e.hot ? `rgba(255,180,40,${ea})` : `rgba(180,80,10,${ea * .6})`;
        ctx.fill();
        if (e.hot && ea > .4) {
          const eg = ctx.createRadialGradient(e.x * W, e.y * H, 0, e.x * W, e.y * H, e.r * 3);
          eg.addColorStop(0, `rgba(255,150,20,${ea * .3})`); eg.addColorStop(1, 'transparent');
          ctx.fillStyle = eg; ctx.fill();
        }
      });

      // ── DUST / ASH STREAKS ──
      dust.forEach(d => {
        d.y += d.vy; if (d.y < .4) d.y = .5 + Math.random() * .3;
        ctx.beginPath();
        ctx.moveTo(d.x * W, d.y * H);
        ctx.lineTo((d.x + d.len) * W, (d.y - d.len * .3) * H);
        ctx.strokeStyle = `rgba(120,100,60,${d.alpha})`; ctx.lineWidth = .7; ctx.stroke();
      });

      requestAnimationFrame(drawWar);
    }
    drawWar();

    /* ── SCROLL REVEAL ── */
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          // Animate skill bars
          e.target.querySelectorAll('.skill-bar-fill').forEach(bar => {
            bar.style.width = bar.dataset.width;
          });
        }
      });
    }, { threshold: .15 });
    document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el => observer.observe(el));

    // Also observe skill cells for bar animation
    const skillObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const bar = e.target.querySelector('.skill-bar-fill');
          if (bar) setTimeout(() => { bar.style.width = bar.dataset.width; }, 200);
        }
      });
    }, { threshold: .3 });
    document.querySelectorAll('.skill-cell').forEach(el => skillObs.observe(el));

    /* ── PARALLAX HERO GLOW ── */
    window.addEventListener('mousemove', e => {
      const g1 = document.querySelector('.hero-glow1');
      const g2 = document.querySelector('.hero-glow2');
      if (!g1) return;
      const rx = (e.clientX / window.innerWidth - .5) * 30;
      const ry = (e.clientY / window.innerHeight - .5) * 30;
      g1.style.transform = `translate(${rx}px,${ry}px) scale(${1 + Math.abs(rx) / 2000})`;
      g2.style.transform = `translate(${-rx * .5}px,${-ry * .5}px)`;
    });

    /* ── TYPING EFFECT in code block ── */
    // Already static, looks great as-is

    /* ── STAGGER REVEALS on load ── */
    window.addEventListener('load', () => {
      document.querySelector('.hero-content').style.opacity = '1';
      document.querySelectorAll('.hero-content > *').forEach((el, i) => {
        el.style.animation = `fadeInUp .7s ${i * .12}s cubic-bezier(.22,1,.36,1) both`;
      });
    });
  </script>

  <style>
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }
  </style>
</body>

</html>
